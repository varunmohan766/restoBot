{
	"_version": "1.85.0",
	"sap.app": {
		"id": "com.bot.resto.restaurantbot",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:basic",
			"version": "1.27.0",
			"toolsId": "0b656de3-05cb-4cbe-9571-4c1eacf09879"
		},
		"supportedLocales": [
			"en"
		],
		"fallbackLocale": "en"
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": false,
		"dependencies": {
			"minUI5Version": "1.149.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.f": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "com.bot.resto.restaurantbot.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": [
				{
					"uri": "css/style.css"
				}
			]
		},
		"routing": {
			"config": {
				"routerClass": "sap.f.routing.Router",
				"type": "View",
				"viewType": "XML",
				"path": "com.bot.resto.restaurantbot.view",
				"controlId": "layout",
				"controlAggregation": "beginColumnPages"
			},
			"routes": [
				{
					"pattern": "",
					"name": "master",
					"target": "master"
				},
				{
					"pattern": "detail/{id}",
					"name": "detail",
					"target": [
						"master",
						"detail"
					]
				},
				{
					"pattern": "stock",
					"name": "stock",
					"target": [
						"stock"
					],
					"layout": "OneColumn"
				}
			],
			"targets": {
				"master": {
					"name": "MasterList",
					"level": 1,
					"id": "master"
				},
				"detail": {
					"name": "OrderDetailsScreen",
					"id": "detail",
					"level": 1,
					"controlAggregation": "midColumnPages"
				},
				"stock": {
					"name": "StockDetails",
					"id": "stock",
					"level": 1,
					"controlAggregation": "beginColumnPages"
				}
			}
		},
		"rootView": {
			"viewName": "com.bot.resto.restaurantbot.view.App",
			"type": "XML",
			"id": "App"
		},
		"flexBundle": false
	}
}